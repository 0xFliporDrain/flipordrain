# enforce LF line endings — keep mac/win checkouts sane
* text=auto eol=lf

# explicit text formats
*.tsx       text eol=lf
*.ts        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.rs        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# binary
*.png       binary
*.jpg       binary
*.svg       binary
*.ico       binary
*.woff2     binary
