# ════ flipordrain env ════
# devnet only — never plug a mainnet rpc here, the program isn't deployed there

# ── anchor cli (program build/deploy/test) ──
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# ── deployed program id (devnet default already in source) ──
PROGRAM_ID=
# switchboard vrf queue — leave empty for pseudo-random devnet resolver
SWITCHBOARD_QUEUE=

# ── helius rpc + ws ──
# grab from https://dev.helius.xyz/dashboard
HELIUS_API_KEY=
# helius websocket endpoint — used by the resolver server for tx subs
HELIUS_WS_URL=wss://devnet.helius-rpc.com/?api-key=

# ── frontend (vite) ──
# rpc the browser hits — devnet helius recommended for low rate-limit pain
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=
VITE_PROGRAM_ID=
# ws server url for live feed + leaderboard fanout
VITE_WS_URL=ws://localhost:3001

# ── ws server ──
WS_PORT=3001
